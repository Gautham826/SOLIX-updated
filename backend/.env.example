# Copy this file to .env for local development.
# In production (Render), set these in your service's Environment tab —
# do NOT commit real values to render.yaml or anywhere else in the repo.

DATABASE_URL=postgresql://user:password@localhost:5432/solix
SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
OPENWEATHER_API_KEY=replace-with-your-new-rotated-key